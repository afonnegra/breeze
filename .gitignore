# Flutter
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/

# Generated Flutter Windows runner artifacts (regenerated by `flutter build`)
windows/flutter/ephemeral/

# Rust
rust/target/
# rust/Cargo.lock is committed (this crate is a de-facto binary)

# Generated bindings are committed (do NOT ignore):
#   lib/src/rust/**          (Dart bindings)
#   rust/src/frb_generated.rs

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Local build artifacts
*.exe
!rust_builder/**/*.exe        # cargokit may vendor one

# Local dev logs
*.log
logs/

# Compiled installer output (installer/breeze.iss is committed)
installer/output/

# Note: test-fixtures/*.wav are committed so the test suite runs on a
# fresh clone; generate-fixtures.ps1 regenerates them if needed.
